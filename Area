  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 20px 5%; display: flex; align-items: center; justify-content: space-between; background: rgba(8,12,20,0.88); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(0,245,160,0.08); }
