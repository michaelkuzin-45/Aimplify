  .ind-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 48px; }
  .ind-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 22px 18px; display: flex; align-items: center; gap: 12px; transition: all 0.25s; }
